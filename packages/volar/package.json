{
  "name": "@veebox/volar",
  "version": "0.0.1",
  "description": "Volar plugin for VBox token hover previews in Vue templates.",
  "keywords": [
    "vue",
    "volar",
    "vbox",
    "design-tokens",
    "hover"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timothyokooboh/vbox.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.cjs",
  "types": "./src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "require": "./src/index.cjs",
      "default": "./src/index.cjs"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "echo \"No compile step required\"",
    "lint": "echo \"No lint script yet\"",
    "test": "node --test tests/**/*.test.cjs"
  },
  "dependencies": {
    "@veebox/core": "^1.1.1",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@vue/compiler-dom": "^3.5.24"
  },
  "engines": {
    "node": ">=18"
  }
}
